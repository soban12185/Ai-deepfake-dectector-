# ===================================================
# AI Deepfake Detector — Environment Variables
# Copy this file to .env and fill in real values
# ===================================================

# Application
APP_NAME="AI Deepfake Detector"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# Security — CHANGE THIS IN PRODUCTION
SECRET_KEY=your-super-secret-key-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (SQLite for local, swap for PostgreSQL in prod)
DATABASE_URL=sqlite:///./deepfake_detector.db
# DATABASE_URL=postgresql://user:password@db:5432/deepfake_db

# File limits
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=100
MAX_FRAMES_TO_ANALYZE=30

# CORS — comma-separated origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Model
MODEL_PATH=models/deepfake_detector.pth
MODEL_INPUT_SIZE=224
MODEL_CONFIDENCE_THRESHOLD=0.5
